# Application
NODE_ENV=development
PORT=3000
APP_NAME=Warehouse API
API_PREFIX=api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
BODY_LIMIT=5mb

# MongoDB
MONGODB_URI=mongodb://localhost:27017/warehouse

# Redis
# false = in-memory cache/sessions, BullMQ o'chiriladi (Redis bo'lmasa avtomatik ham o'chadi)
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=3650d

# Session (Redis-backed)
SESSION_SECRET=dev-session-secret-change-in-production
SESSION_MAX_AGE=86400000

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# Seed admin (npm run seed:admin yoki dev ishga tushganda avtomatik)
SEED_ADMIN_ON_STARTUP=true
SEED_ADMIN_LOGIN=admin
SEED_ADMIN_PASSWORD=123123
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=Administrator
# Eski admin (email bilan) bo'lsa, migratsiya uchun:
# SEED_ADMIN_EMAIL=admin@warehouse.uz
