# API — LAN uchun /api qoldiring (Vite proxy orqali backendga yo'naltiradi)
VITE_API_URL=/api
# To'g'ridan-to'g'ri backend: VITE_API_URL=http://<sizning-IP>:3000/api
VITE_WS_URL=

# QR / telefon uchun frontend manzili (faqat localhost da ishlaganda kerak)
# Masalan: VITE_PUBLIC_APP_URL=http://192.168.1.100:5173
# Domen bilan ishlasangiz brauzer o'sha domen orqali ochilgan bo'lsa sozlash shart emas
VITE_PUBLIC_APP_URL=

# Polling (TanStack Query)
VITE_INVENTORY_POLL_INTERVAL_MS=5000

# Scanner
VITE_SCANNER_DEVICE_ID=scanner-01
VITE_SCANNER_DEBOUNCE_MS=100
VITE_SCANNER_MIN_LENGTH=4

# Printer
VITE_PRINTER_DEFAULT_LABEL_WIDTH_MM=50
VITE_PRINTER_DEFAULT_LABEL_HEIGHT_MM=30

# Printer
VITE_PRINTER_DEFAULT_LABEL_WIDTH_MM=50
VITE_PRINTER_DEFAULT_LABEL_HEIGHT_MM=30
